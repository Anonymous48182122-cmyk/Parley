# Both free, no credit card required. Gemini is primary, Groq is the
# cross-provider fallback (used if Gemini is overloaded/rate-limited).
GEMINI_API_KEY=...  # https://aistudio.google.com/apikey
GROQ_API_KEY=...    # https://console.groq.com/keys

# Supabase project settings (Project Settings -> API). service_role and the
# JWT secret are server-side secrets — never send these to the frontend.
SUPABASE_URL=...
SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_JWT_SECRET=...

# Vite only exposes VITE_-prefixed vars to the browser bundle. This is the
# public "anon" key — safe to ship client-side, protected by the saved_debates
# table's Row Level Security policy on Supabase's end. Never put the
# service_role key or JWT secret here.
VITE_SUPABASE_URL=...
VITE_SUPABASE_ANON_KEY=...

# Leave blank for local dev (Vite proxies /api to localhost:8420 — see
# vite.config.js). In production (Vercel), set this to the deployed backend's
# URL, e.g. https://parley-api.onrender.com
VITE_API_BASE_URL=
